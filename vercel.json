{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "realestate.corywong.ca" }],
      "destination": "/realestate"
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "re.corywong.ca" }],
      "destination": "/realestate"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.corywong.ca" }],
      "destination": "https://corywong.ca/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
