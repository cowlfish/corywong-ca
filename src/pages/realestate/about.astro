---
import RealestateLayout from '../../layouts/RealestateLayout.astro';
import CtaButton from '../../components/CtaButton.astro';
---

<RealestateLayout
  title="About Cory Wong"
  description="Meet Cory Wong, Real Estate Agent at Trustwell Realty Inc., Brokerage. Serving buyers and sellers across the Greater Toronto Area with clear, technology-forward guidance."
  canonicalPath="/about"
>
  <section class="about-hero">
    <div class="container">
      <div class="about-hero__content">
        <img src="/headshot.jpg" alt="Cory Wong, Real Estate Agent" class="about-hero__photo" width="280" height="280" />
        <div class="about-hero__text">
          <h1>About Cory Wong</h1>
          <p class="about-hero__title">Real Estate Agent</p>
          <p class="about-hero__brokerage">Trustwell Realty Inc., Brokerage</p>
        </div>
      </div>
    </div>
  </section>

  <section class="about-body">
    <div class="container">
      <div class="about-body__content">
        <p>
          I'm a real estate professional serving the Greater Toronto Area, with a focus on
          Toronto, Markham, and Richmond Hill. I also work with clients across the Peel,
          York, and Durham regions.
        </p>
        <p>
          My approach to real estate is built on clarity, honesty, and attention to detail.
          I believe every client deserves straightforward advice — not sales pressure — and
          I bring a technology-forward mindset to help you make informed decisions.
        </p>
        <p>
          Whether you're a first-time buyer navigating a competitive market, a homeowner
          looking to sell at the right time, or an investor evaluating opportunities, I'm
          here to guide you through every step of the process.
        </p>

        <h2>My Commitment to You</h2>
        <ul class="values-list">
          <li><strong>Transparency</strong> — You'll always know where things stand. No hidden agendas, no surprises.</li>
          <li><strong>Data-Driven Advice</strong> — Decisions backed by market data, not guesswork.</li>
          <li><strong>Responsiveness</strong> — Your questions answered promptly, your concerns addressed.</li>
          <li><strong>Client-First Approach</strong> — Your goals drive the process, not mine.</li>
        </ul>

        <h2>Service Areas</h2>
        <p>
          <strong>Primary markets:</strong> Toronto, Markham, Richmond Hill<br />
          <strong>Additional coverage:</strong> Peel Region, York Region, Durham Region
        </p>
      </div>

      <div class="about-cta">
        <h2>Let's Talk</h2>
        <p>Ready to discuss your real estate goals? Book a free, no-obligation consultation.</p>
        <CtaButton href="/contact" label="Book a Consultation" variant="primary" />
      </div>
    </div>
  </section>
</RealestateLayout>

<style>
  .about-hero {
    padding: var(--space-2xl) 0 var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }

  .about-hero__content {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
  }

  .about-hero__photo {
    width: 280px;
    height: 280px;
    border-radius: 12px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .about-hero h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-xs);
  }

  .about-hero__title {
    font-size: 1.125rem;
    color: var(--color-accent);
    font-weight: 500;
    margin-bottom: var(--space-xs);
  }

  .about-hero__brokerage {
    font-size: 1rem;
    color: var(--color-text-muted);
  }

  .about-body {
    padding: var(--space-xl) 0;
  }

  .about-body__content {
    max-width: 36rem;
  }

  .about-body__content p {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .about-body__content h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: var(--space-lg);
    margin-bottom: var(--space-md);
    color: var(--color-text);
  }

  .values-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .values-list li {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    padding-left: 1.5rem;
    position: relative;
  }

  .values-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5rem;
    width: 8px;
    height: 8px;
    background: var(--color-accent);
    border-radius: 50%;
  }

  .about-cta {
    margin-top: var(--space-xl);
    padding: var(--space-xl);
    background: #f5f5f4;
    border-radius: 12px;
    text-align: center;
  }

  .about-cta h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: var(--space-sm);
  }

  .about-cta p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  @media (max-width: 640px) {
    .about-hero__content {
      flex-direction: column;
      text-align: center;
    }

    .about-hero__photo {
      width: 200px;
      height: 200px;
    }
  }
</style>
