---
import RealestateLayout from '../../../layouts/RealestateLayout.astro';
import CtaButton from '../../../components/CtaButton.astro';
import NewsletterSignup from '../../../components/NewsletterSignup.astro';
---

<RealestateLayout
  title="Market Updates"
  description="GTA real estate market updates, trends, and insights from Cory Wong, Real Estate Agent at Trustwell Realty Inc., Brokerage."
  canonicalPath="/market-updates"
>
  <section class="page-hero">
    <div class="container">
      <h1>GTA Market Updates</h1>
      <p class="page-hero__subtitle">
        Regular insights on Greater Toronto Area real estate trends, pricing data,
        and neighbourhood developments to help you make informed decisions.
      </p>
    </div>
  </section>

  <section class="coming-soon">
    <div class="container">
      <div class="coming-soon__card">
        <h2>Market updates are coming soon</h2>
        <p>
          I'm preparing regular market reports covering sales data, pricing trends, and
          neighbourhood-level insights across the GTA. Subscribe below to be notified
          when the first update is published.
        </p>
        <CtaButton href="/contact" label="Book a Consultation" variant="primary" />
      </div>
    </div>
  </section>

  <NewsletterSignup heading="Get Market Updates in Your Inbox" />
</RealestateLayout>

<style>
  .page-hero {
    padding: var(--space-2xl) 0 var(--space-xl);
    text-align: center;
  }

  .page-hero h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-md);
  }

  .page-hero__subtitle {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 34rem;
    margin: 0 auto;
    line-height: 1.6;
  }

  .coming-soon {
    padding: var(--space-xl) 0 var(--space-2xl);
  }

  .coming-soon__card {
    max-width: 32rem;
    margin: 0 auto;
    text-align: center;
    padding: var(--space-xl);
    background: #f5f5f4;
    border-radius: 12px;
    border: 1px solid var(--color-border);
  }

  .coming-soon__card h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: var(--space-md);
  }

  .coming-soon__card p {
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-lg);
  }
</style>
