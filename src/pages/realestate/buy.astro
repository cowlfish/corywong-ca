---
import RealestateLayout from '../../layouts/RealestateLayout.astro';
import CtaButton from '../../components/CtaButton.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
---

<RealestateLayout
  title="Buyer Services"
  description="Looking to buy a home in the Greater Toronto Area? Cory Wong guides buyers from pre-approval through closing with clear, honest advice."
  canonicalPath="/buy"
>
  <section class="page-hero">
    <div class="container">
      <h1>Buying a Home in the GTA</h1>
      <p class="page-hero__subtitle">
        From your first search to getting the keys, I'll help you navigate
        the Greater Toronto Area market with confidence.
      </p>
    </div>
  </section>

  <section class="content-section">
    <div class="container">
      <h2>How I Help Buyers</h2>
      <div class="process-steps">
        <div class="step">
          <span class="step__number">1</span>
          <h3>Consultation &amp; Pre-Approval</h3>
          <p>We'll discuss your goals, budget, and timeline. I'll connect you with trusted mortgage professionals to get pre-approved and set realistic expectations.</p>
        </div>
        <div class="step">
          <span class="step__number">2</span>
          <h3>Neighbourhood Research</h3>
          <p>I'll help you identify the right neighbourhoods based on your priorities — commute, schools, amenities, investment potential, and lifestyle fit.</p>
        </div>
        <div class="step">
          <span class="step__number">3</span>
          <h3>Property Search &amp; Showings</h3>
          <p>Curated listings matched to your criteria, with honest assessments of each property's condition, value, and potential concerns.</p>
        </div>
        <div class="step">
          <span class="step__number">4</span>
          <h3>Offer Strategy &amp; Negotiation</h3>
          <p>Data-driven offer strategy with skilled negotiation to get you the best possible price and terms in any market condition.</p>
        </div>
        <div class="step">
          <span class="step__number">5</span>
          <h3>Inspection, Conditions &amp; Closing</h3>
          <p>I'll coordinate inspections, manage conditions, and guide you through closing — so there are no surprises on moving day.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <h2>Frequently Asked Questions</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>How much do I need for a down payment in Ontario?</summary>
          <p>The minimum down payment in Canada is 5% for homes under $500,000, and 10% on the portion between $500,000 and $1,500,000. Homes over $1,500,000 require 20% down. Your mortgage professional can help determine the best approach for your situation.</p>
        </details>
        <details class="faq-item">
          <summary>Do I pay your fees as a buyer?</summary>
          <p>Buyer representation agreements outline how your agent is compensated. I'll explain all fee structures transparently during our initial consultation so there are no surprises.</p>
        </details>
        <details class="faq-item">
          <summary>How long does the buying process take?</summary>
          <p>From start to close, most purchases take 30 to 90 days once you're pre-approved and actively looking. In competitive markets, timelines can be shorter. I'll set realistic expectations based on current conditions.</p>
        </details>
        <details class="faq-item">
          <summary>Should I get a home inspection?</summary>
          <p>I strongly recommend home inspections for all purchases. A qualified inspector can identify issues that could cost thousands to repair. I'll help you understand the findings and negotiate accordingly.</p>
        </details>
        <details class="faq-item">
          <summary>What areas do you serve?</summary>
          <p>I primarily serve Toronto, Markham, and Richmond Hill, with additional coverage across the Peel, York, and Durham regions. If you're looking in the broader GTA, let's chat about your target area.</p>
        </details>
      </div>
    </div>
  </section>

  <section class="lead-form-section" id="inquiry">
    <div class="container">
      <h2>Tell Me What You're Looking For</h2>
      <p class="lead-form-section__subtitle">Share your preferences and I'll follow up with relevant listings and insights.</p>
      <form class="lead-form" id="buyer-form" data-form-type="buyer">
        <div class="form-row">
          <div class="form-field">
            <label for="buyer-name">Name</label>
            <input type="text" id="buyer-name" name="name" required autocomplete="name" />
          </div>
          <div class="form-field">
            <label for="buyer-email">Email</label>
            <input type="email" id="buyer-email" name="email" required autocomplete="email" />
          </div>
        </div>
        <div class="form-row">
          <div class="form-field">
            <label for="buyer-budget">Budget Range</label>
            <select id="buyer-budget" name="budget">
              <option value="">Select a range</option>
              <option value="under-500k">Under $500,000</option>
              <option value="500k-750k">$500,000 – $750,000</option>
              <option value="750k-1m">$750,000 – $1,000,000</option>
              <option value="1m-1.5m">$1,000,000 – $1,500,000</option>
              <option value="1.5m-plus">$1,500,000+</option>
            </select>
          </div>
          <div class="form-field">
            <label for="buyer-timeline">Timeline</label>
            <select id="buyer-timeline" name="timeline">
              <option value="">Select timeline</option>
              <option value="asap">As soon as possible</option>
              <option value="1-3months">1–3 months</option>
              <option value="3-6months">3–6 months</option>
              <option value="6-12months">6–12 months</option>
              <option value="exploring">Just exploring</option>
            </select>
          </div>
        </div>
        <div class="form-field">
          <label for="buyer-neighbourhoods">Preferred Neighbourhoods</label>
          <input type="text" id="buyer-neighbourhoods" name="neighbourhoods" placeholder="e.g., Markham, Richmond Hill, North York" />
        </div>
        <div class="form-field">
          <label for="buyer-notes">Anything else I should know?</label>
          <textarea id="buyer-notes" name="notes" rows="3"></textarea>
        </div>
        <button type="submit" class="form-submit">Send Inquiry</button>
        <p class="form-status" id="buyer-form-status" aria-live="polite"></p>
      </form>
    </div>
  </section>

  <section class="cta-banner">
    <div class="container">
      <h2>Ready to Start Your Search?</h2>
      <p>Book a free consultation to discuss your home buying goals.</p>
      <CtaButton href="/contact" label="Book a Consultation" variant="primary" />
    </div>
  </section>

  <NewsletterSignup />
</RealestateLayout>

<script>
  const form = document.getElementById('buyer-form') as HTMLFormElement;
  const status = document.getElementById('buyer-form-status') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    status.textContent = 'Sending...';
    status.className = 'form-status';

    const data = Object.fromEntries(new FormData(form));

    try {
      const res = await fetch('/api/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ...data, type: 'buyer' }),
      });

      if (res.ok) {
        status.textContent = 'Thank you! I\'ll be in touch soon.';
        status.classList.add('form-status--success');
        form.reset();
      } else {
        throw new Error('Failed');
      }
    } catch {
      status.textContent = 'Something went wrong. Please email directly or try again.';
      status.classList.add('form-status--error');
    }
  });
</script>

<style>
  .page-hero {
    padding: var(--space-2xl) 0 var(--space-xl);
    text-align: center;
  }

  .page-hero h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-md);
  }

  .page-hero__subtitle {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 34rem;
    margin: 0 auto;
    line-height: 1.6;
  }

  .content-section {
    padding: var(--space-xl) 0;
  }

  .content-section h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: var(--space-lg);
    text-align: center;
  }

  .process-steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    max-width: 36rem;
    margin: 0 auto;
  }

  .step {
    position: relative;
    padding-left: 3.5rem;
  }

  .step__number {
    position: absolute;
    left: 0;
    top: 0;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent);
    color: #fff;
    border-radius: 50%;
    font-weight: 700;
    font-size: 0.875rem;
  }

  .step h3 {
    font-size: 1.0625rem;
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }

  .step p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .faq-section {
    padding: var(--space-xl) 0;
    background: #f5f5f4;
  }

  .faq-section h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: var(--space-lg);
    text-align: center;
  }

  .faq-list {
    max-width: 36rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .faq-item {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-md);
  }

  .faq-item summary {
    font-weight: 600;
    font-size: 0.9375rem;
    cursor: pointer;
    list-style: none;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item[open] summary {
    margin-bottom: var(--space-sm);
  }

  .faq-item p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .lead-form-section {
    padding: var(--space-xl) 0;
  }

  .lead-form-section h2 {
    font-size: 1.5rem;
    font-weight: 600;
    text-align: center;
    margin-bottom: var(--space-xs);
  }

  .lead-form-section__subtitle {
    text-align: center;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .lead-form {
    max-width: 32rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .form-field label {
    font-size: 0.875rem;
    font-weight: 500;
  }

  .form-field input,
  .form-field select,
  .form-field textarea {
    padding: 0.625rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 0.9375rem;
    font-family: var(--font-sans);
    background: var(--color-surface);
    transition: border-color 0.15s ease;
  }

  .form-field input:focus,
  .form-field select:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(15, 118, 110, 0.1);
  }

  .form-submit {
    padding: 0.75rem 1.75rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.9375rem;
    background: var(--color-accent);
    color: #ffffff;
    border: none;
    cursor: pointer;
    transition: background-color 0.15s ease;
  }

  .form-submit:hover {
    background: var(--color-accent-hover);
  }

  .form-status {
    text-align: center;
    font-size: 0.875rem;
    min-height: 1.25rem;
  }

  .form-status--success {
    color: var(--color-accent);
  }

  .form-status--error {
    color: #dc2626;
  }

  .cta-banner {
    padding: var(--space-xl) 0;
    text-align: center;
    background: #f5f5f4;
    border-top: 1px solid var(--color-border);
  }

  .cta-banner h2 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: var(--space-sm);
  }

  .cta-banner p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
